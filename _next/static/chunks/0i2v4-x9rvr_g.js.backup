}`,o=`
precision highp float;
varying vec2 vUv;
uniform vec2 uResolution;
uniform sampler2D uImage;
uniform sampler2D uDepth;
uniform vec2 uImageScale;
uniform vec2 uMouseEase;
uniform float uTime;
uniform float uHover;

vec2 containUv(vec2 uv, vec2 viewport, vec2 image) {
  float vr = viewport.x / viewport.y;
  float ir = image.x / image.y;
  vec2 scale = vec2(1.0);
  if (vr > ir) scale.x = ir / vr; else scale.y = vr / ir;
  return (uv - 0.5) / scale + 0.5;
}

void main() {
  vec2 contained = containUv(vUv, uResolution, uImageScale);
  bool outside = contained.x < 0.0 || contained.x > 1.0 || contained.y < 0.0 || contained.y > 1.0;
  vec3 bg = vec3(1.0);
  if (outside) { gl_FragColor = vec4(bg, 1.0); return; }
  vec2 mouse = (uMouseEase - 0.5) * vec2(2.0, -2.0);
  float depth = texture2D(uDepth, contained).r;
  float breathing = sin(uTime * 0.0012) * 0.5 + 0.5;
  float amount = (0.03 + 0.012 * breathing) * uHover;
  vec2 disp = mouse * depth * amount;
  vec2 uv = contained - disp;
  float r = texture2D(uImage, uv + disp * 0.16).r;
  float g = texture2D(uImage, uv).g;
  float b = texture2D(uImage, uv - disp * 0.16).b;
  float a = texture2D(uImage, uv).a;
  vec3 color = mix(bg, vec3(r,g,b), a);
  gl_FragColor = vec4(color, 1.0);
}`;e.s(["default",0,function({className:e="",onLoad:c,onPreviewLoad:d,children:u}){return null}])},17065,e=>{"use strict";var t=e.i(43476),a=e.i(71645),r=e.i(65747),l=e.i(89970),n=e.i(81371),i=e.i(70207);e.i(83390);var s=e.i(90782),o=e.i(75324);l.default.registerPlugin(o.default);let c=(0,a.forwardRef)(({text:e,html:n,as:i="span",className:s="",animationType:c="words",stagger:d=.05,duration:u=.8,ease:m="power2.out",delay:h=0,from:p="random"},f)=>{let x=(0,a.useRef)(null),g=(0,a.useRef)(null),w=(0,a.useRef)(null);return(0,a.useImperativeHandle)(f,()=>({play(){g.current||(w.current?.(),w.current=(()=>{if(!x.current)return()=>{};let e=new o.default(x.current,{type:"chars,words,lines",smartWrap:!0,wordsClass:"words",charsClass:"chars",linesClass:"lines"});x.current.removeAttribute("aria-label");let t="lines"===c?e.lines:"chars"===c?e.chars:e.words;l.default.set([x.current,t],{autoAlpha:0,filter:"blur(12px)",force3D:!0});let a=l.default.timeline({paused:!0});return a.to(x.current,{autoAlpha:1,filter:"blur(0px)",duration:.5,ease:m},h).to(t,{autoAlpha:1,filter:"blur(0px)",duration:u,stagger:{each:d,from:p},ease:m},h),g.current=a,()=>{a.kill(),g.current=null,e.revert()}})()),g.current?.restart()}})),(0,r.useGSAP)(()=>{if(x.current)return l.default.set(x.current,{autoAlpha:0,filter:"blur(12px)"}),()=>{w.current?.(),w.current=null}},[]),(0,t.jsx)(i,{ref:x,className:s,style:{visibility:"hidden",willChange:"filter, opacity"},dangerouslySetInnerHTML:n?{__html:n}:void 0,children:n?null:e})});c.displayName="AboutHeroBlurText";var d=e.i(36894);e.i(11303);var u=e.i(62749);l.default.registerPlugin(o.SplitText);let m=(0,t.jsxs)("svg",{width:"40",height:"40",viewBox:"0 0 40 40",fill:"none",xmlns:"http://www.w3.org/2000/svg",className:"mx-10 lg:mx-16 w-6 lg:w-8 h-6 lg:h-8 mt-2","aria-hidden":!0,children:[(0,t.jsx)("line",{x1:"20.2256",y1:"-2.18557e-08",x2:"20.2256",y2:"40",stroke:"currentColor"}),(0,t.jsx)("line",{x1:"40",y1:"20.226",x2:"-4.37114e-08",y2:"20.226",stroke:"currentColor"})